logs/
*.log

# Coverage directory used by tools like istanbul
coverage/

# Temporary files
tmp/
temp/

# Upload directories
uploads/
public/uploads/

# MongoDB data
data/
dump/

# AWS credentials
aws-credentials.json

# Project specific
*.pem
*.key
*.cert
